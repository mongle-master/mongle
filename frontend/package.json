{
  "name": "frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite dev",
    "seed:people": "node scripts/seed-people.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "eslint --fix && prettier --write .",
    "check": "prettier --check .",
    "ci": "pnpm run lint && pnpm run check && pnpm run typecheck && pnpm run build",
    "prepare": "cd .. && husky frontend/.husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource/pretendard": "^5.2.5",
    "@hookform/resolvers": "^5.4.0",
    "@stackflow/config": "^2.0.0",
    "@stackflow/core": "^2.0.1",
    "@stackflow/plugin-basic-ui": "^1.18.2",
    "@stackflow/plugin-history-sync": "^1.11.2",
    "@stackflow/plugin-renderer-basic": "^1.1.14",
    "@stackflow/react": "^2.1.1",
    "@suspensive/react": "^3.21.3",
    "@suspensive/react-query": "^3.21.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/blob": "^2.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "ky": "^2.0.2",
    "lucide-react": "^0.545.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.1",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@julr/vite-plugin-validate-env": "^2.2.2",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "code-inspector-plugin": "^1.6.4",
    "eslint": "^9.20.0",
    "eslint-plugin-storybook": "^10.4.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.8.1",
    "storybook": "^10.4.6",
    "typescript": "^6.0.2",
    "vercel": "^55.0.0",
    "vite": "^8.0.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  }
}
