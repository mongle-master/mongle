{
  "name": "frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
