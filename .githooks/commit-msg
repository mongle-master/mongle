#!/bin/sh
# =============================================================================
# commit-msg 훅 — Angular(Conventional Commits) 커밋 규칙 검증
# 헤더 형식은 영어 type/scope, 제목(subject)은 한국어로 작성한다.
# =============================================================================

msg_file="$1"

# 주석(#)·빈 줄을 제외한 첫 줄 = 헤더
header=$(grep -vE '^[[:space:]]*#' "$msg_file" | grep -vE '^[[:space:]]*$' | head -n1)

# merge / revert / fixup / squash 자동 커밋은 통과
case "$header" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*) exit 0 ;;
esac

types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
pattern="^(${types})(\([a-z0-9,/*-]+\))?!?: .+"

if printf '%s' "$header" | grep -qE "$pattern"; then
  # 헤더 길이 권고(100자) — 초과해도 막지 않고 경고만
  len=$(printf '%s' "$header" | awk '{print length}')
  if [ "$len" -gt 100 ]; then
    echo "⚠️  커밋 헤더가 100자를 초과했습니다(${len}자). 가능하면 줄여주세요."
  fi
  exit 0
fi

cat <<'EOF'
✗ 커밋 메시지 형식이 올바르지 않습니다 (Angular / Conventional Commits).

  형식:  <type>(<scope>): <제목>
         · <scope> 는 선택 (예: frontend, backend, prd)
         · <제목> 은 한국어로 작성

  type:
    feat      새 기능
    fix       버그 수정
    docs      문서
    style     포맷·스타일 (동작 변화 없음)
    refactor  리팩터링 (기능 변화 없음)
    perf      성능 개선
    test      테스트
    build     빌드·의존성
    ci        CI 설정
    chore     기타 잡무
    revert    되돌리기

  예시:
    feat(backend): 인물 등록 API 추가
    fix(frontend): 타임라인 정렬 오류 수정
    docs(prd): 기록 작성 화면 상세 스펙 보강
EOF
exit 1
